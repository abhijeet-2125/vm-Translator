// Main.vm  —  Sets up 2×2 test matrices and calls MAC.matmul
//
// W = [[1, 2],     X = [[5, 6],     B = [[1],
//      [3, 4]]          [7, 8]]          [2]]
//
// W·X = [[1*5+2*7, 1*6+2*8],  = [[19, 22],
//         [3*5+4*7, 3*6+4*8]]     [43, 50]]
//
// Y = W·X + B (broadcast) = [[20, 23],
//                             [45, 52]]
//
// W stored at RAM[100..103], X at RAM[200..203], B at RAM[300..301]

function Main.run 0
    // ── Write W into RAM[100..103] ─────────────────────────────────────────
    push constant 100
    pop pointer 1        // THAT = 100
    push constant 1
    pop that 0           // W[0][0] = 1
    push constant 101
    pop pointer 1
    push constant 2
    pop that 0           // W[0][1] = 2
    push constant 102
    pop pointer 1
    push constant 3
    pop that 0           // W[1][0] = 3
    push constant 103
    pop pointer 1
    push constant 4
    pop that 0           // W[1][1] = 4

    // ── Write X into RAM[200..203] ─────────────────────────────────────────
    push constant 200
    pop pointer 1
    push constant 5
    pop that 0           // X[0][0] = 5
    push constant 201
    pop pointer 1
    push constant 6
    pop that 0           // X[0][1] = 6
    push constant 202
    pop pointer 1
    push constant 7
    pop that 0           // X[1][0] = 7
    push constant 203
    pop pointer 1
    push constant 8
    pop that 0           // X[1][1] = 8

    // ── Write B (bias) into RAM[300..301] ─────────────────────────────────
    push constant 300
    pop pointer 1
    push constant 1
    pop that 0           // B[0] = 1
    push constant 301
    pop pointer 1
    push constant 2
    pop that 0           // B[1] = 2

    // ── Call MAC.matmul(w_ptr=100, x_ptr=200, b_ptr=300, rows=2, cols=2, inner=2)
    push constant 100    // w_ptr
    push constant 200    // x_ptr
    push constant 300    // b_ptr
    push constant 2      // rows
    push constant 2      // cols
    push constant 2      // inner
    call MAC.matmul 6

    // return value is y_ptr (400); result matrix Y lives at RAM[400..403]
    return
